<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <schema path="/io/github/davidoc26/wallpaper_selector/" id="@app-id@"
    gettext-domain="@gettext-package@">
    <key name="window-width" type="i">
      <default>600</default>
      <summary>Window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>400</default>
      <summary>Window height</summary>
    </key>
    <key name="is-maximized" type="b">
      <default>false</default>
      <summary>Window maximized state</summary>
    </key>
    <key name="category" type="i">
      <default>0</default>
      <summary>Wallpapers category</summary>
    </key>
    <key name="wallpapers-sorting" type="s">
      <choices>
        <choice value="Latest" />
        <choice value="Toplist" />
        <choice value="Hot" />
        <choice value="Random" />
      </choices>
      <default>'Latest'</default>
    </key>
    <key name="category-general" type="b">
      <default>true</default>
    </key>
    <key name="category-anime" type="b">
      <default>true</default>
    </key>
    <key name="category-people" type="b">
      <default>false</default>
    </key>
  </schema>
</schemalist>
